# Python virtual environments and caches
__pycache__/
*.py[cod]
*$py.class
.venv/
venv/
env/
ENV/
*.egg-info/
.eggs/

# IDE and system files
.vscode/
.idea/
.gemini/
.DS_Store
Thumbs.db

# Keep original test inputs, but ignore user-uploaded files
input/*
!input/Red_Herring_Prospectus.docx
!input/sample_test.docx

# Ignore all generated outputs
output/*
!output/.gitkeep

# Ignore logs and runtime reports
*.log
reports/*
!reports/ground_truth.json
